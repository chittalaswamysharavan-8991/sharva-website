# Public browser vars used by the Vite app and Supabase client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only Supabase key used by scheduled sync jobs and admin writes.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only secret used to sign connector OAuth state.
CONNECTOR_STATE_SECRET=

# Server-only Vercel environment variables for future connector APIs.
# Do not prefix these with VITE_.
# Notion connector
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Google Calendar connector
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Future Make connector
MAKE_API_TOKEN=
